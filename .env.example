# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://aviatoriq:yourpassword@localhost:3306/aviatoriq

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Required: used for lead AI summaries and roadmap generation
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: override the default API base URL (e.g. for Azure OpenAI or proxies)
# OPENAI_API_BASE=https://api.openai.com/v1
# Optional: model to use for AI features (default: gpt-4o-mini)
LLM_MODEL=gpt-4.1-mini

# ─── Auth / Session ───────────────────────────────────────────────────────────
# Required: change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-in-production
ADMIN_NAME=AviatorIQ Admin
OWNER_OPEN_ID=admin

# ─── Storage ──────────────────────────────────────────────────────────────────
# Local directory for PDF blueprints and uploaded files (relative to project root)
# NOTE: On Railway, add a persistent volume mounted at /app/uploads
LOCAL_STORAGE_PATH=uploads

# Optional: AWS S3 for persistent file storage across deploys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-2
# S3_BUCKET_NAME=aviatoriq-uploads

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Set to your Umami instance URL and website ID; leave empty to disable tracking
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Pexels (Stock Photos) ────────────────────────────────────────────────────
# Required: Used to serve all site images via the /manus-storage/ proxy
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here
