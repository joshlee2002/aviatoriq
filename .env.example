# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://aviatoriq:yourpassword@localhost:3306/aviatoriq

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Optional: used for AI roadmap generation and lead summaries.
# Without this key the server still starts, but AI roadmap generation will use
# a structured fallback and PDF blueprints will contain data-only content.
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: override the default API base URL (e.g. for Azure OpenAI or proxies)
# OPENAI_API_BASE=https://api.openai.com/v1
# Optional: model to use for AI features (default: gpt-4o-mini)
LLM_MODEL=gpt-4.1-mini

# ─── Auth / Session ───────────────────────────────────────────────────────────
# Required: change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-in-production
ADMIN_NAME=AviatorIQ Admin
OWNER_OPEN_ID=admin

# ─── Storage ──────────────────────────────────────────────────────────────────
# Local directory for PDF blueprints and uploaded files (relative to project root)
# NOTE: On Railway, files written here will NOT persist across deploys unless you
# add a persistent volume mounted at /app/uploads — or use R2/S3 below.
LOCAL_STORAGE_PATH=uploads

# Optional: Cloudflare R2 (or any S3-compatible) for persistent file storage.
# When set, all new file uploads go to the remote bucket.
# Existing files in uploads/ (e.g. the 109 seed images) continue to be served locally.
# See DEPLOYMENT.md for full setup instructions.
#
# STORAGE_BUCKET_URL=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_BUCKET_NAME=aviatoriq
# STORAGE_ACCESS_KEY_ID=<r2-access-key-id>
# STORAGE_SECRET_ACCESS_KEY=<r2-secret-access-key>
# STORAGE_PUBLIC_CDN_URL=https://pub-<hash>.r2.dev  # optional: public bucket URL
# STORAGE_REGION=auto  # use 'auto' for R2, or e.g. 'eu-west-2' for AWS S3

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Set to your Umami instance URL and website ID; leave empty to disable tracking
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Pexels (Stock Photos) ────────────────────────────────────────────────────
# Required: Used to serve all site images via the /manus-storage/ proxy
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Stripe (Premium Roadmap) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
